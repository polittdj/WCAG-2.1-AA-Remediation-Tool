<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>WCAG 2.1 AA Batch Summary Report</title>
<style>
:root {
  --pass: #0f6e2a; --pass-bg: #e6f4ea;
  --fail: #a8201d; --fail-bg: #fce8e6;
  --warn: #8a4a00; --warn-bg: #fef7e0;
  --na: #666; --na-bg: #f5f5f5;
  --text: #222; --bg: #fff; --border: #ccc;
  --header-bg: #f0f0f0;
}
@media (prefers-color-scheme: dark) {
  :root {
    --text: #e0e0e0; --bg: #1a1a1a; --border: #444;
    --header-bg: #2a2a2a;
    --pass-bg: #1b3a26; --fail-bg: #3a1b1b;
    --warn-bg: #3a2e1b; --na-bg: #2a2a2a;
  }
}
*, *::before, *::after { box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
       max-width: 1000px; margin: 0 auto; padding: 1em;
       color: var(--text); background: var(--bg); line-height: 1.5; }
a { color: #3f51b5; }
a.skip-link { position: absolute; left: -9999px; top: 0; padding: 0.5em 1em;
              background: var(--bg); z-index: 100; }
a.skip-link:focus { left: 0; }
header { border-bottom: 2px solid var(--text); padding-bottom: 0.5em; margin-bottom: 1em; }
header h1 { margin: 0 0 0.25em; font-size: 1.5em; }
table { border-collapse: collapse; width: 100%; margin: 1em 0; }
th, td { border: 1px solid var(--border); padding: 0.4em 0.6em;
         text-align: left; vertical-align: top; }
th { background: var(--header-bg); font-weight: 600; }
.badge { display: inline-block; padding: 0.2em 0.5em; border-radius: 4px;
         font-weight: 700; font-size: 0.9em; }
.badge.pass { background: var(--pass-bg); color: var(--pass); }
.badge.partial { background: var(--warn-bg); color: var(--warn); }
footer { border-top: 1px solid var(--border); margin-top: 2em; padding-top: 1em;
         color: var(--na); font-size: 0.85em; }
.table-wrap { overflow-x: auto; }
@media print {
  body { max-width: 100%; font-size: 10pt; }
  a.skip-link { display: none; }
}
@media (max-width: 600px) {
  table { font-size: 0.85em; }
  th, td { padding: 0.3em; }
}
</style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>

<header>
  <h1>WCAG 2.1 AA Batch Summary Report</h1>
  <p>WCAG 2.1 AA PDF Conversion &amp; Verification Tool v3</p>
</header>

<main id="main-content">
  <section aria-label="Batch information">
    <p><strong>Processed:</strong> {{ timestamp | e }}</p>
    <p><strong>Total files:</strong> {{ files | length }}</p>
    <p><strong>Results:</strong>
      <span class="badge pass">&#x2713; PASS: {{ pass_count }}</span>
      <span class="badge partial">&#x26A0; PARTIAL: {{ partial_count }}</span>
    </p>
  </section>

  <section aria-label="Per-file results">
    <h2>Per-File Results</h2>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">Filename</th>
          <th scope="col">Result</th>
          <th scope="col">Passed</th>
          <th scope="col">Failed</th>
          <th scope="col">Manual</th>
          <th scope="col">Report</th>
        </tr>
      </thead>
      <tbody>
      {% for f in files %}
        <tr>
          <td>{{ loop.index }}</td>
          <td>{{ f.filename | e }}</td>
          <td><span class="badge {{ f.result | lower }}">{{ f.result | e }}</span></td>
          <td>{{ f.pass_count }}</td>
          <td>{{ f.fail_count }}</td>
          <td>{{ f.review_count }}</td>
          <td>{% if f.report_name %}<a href="{{ f.report_name | e }}">View</a>{% else %}—{% endif %}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    </div>
  </section>

  <script type="application/json" id="wcag-batch-data">
{{ json_data | safe }}
  </script>
</main>

<noscript>
<section aria-label="Batch results (no JavaScript)">
  <h2>Per-File Results</h2>
  <table>
    <thead><tr><th scope="col">#</th><th scope="col">Filename</th><th scope="col">Result</th><th scope="col">Passed</th><th scope="col">Failed</th></tr></thead>
    <tbody>
    {% for f in files %}
      <tr><td>{{ loop.index }}</td><td>{{ f.filename | e }}</td><td>{{ f.result | e }}</td><td>{{ f.pass_count }}</td><td>{{ f.fail_count }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>
</noscript>

<footer>
  <p>Your files were processed in memory and deleted immediately after your download was ready.
  No file content was stored, logged, or shared. All transfers were encrypted (HTTPS).</p>
  <p>Generated by WCAG 2.1 AA PDF Conversion &amp; Verification Tool v3</p>
</footer>
</body>
</html>
