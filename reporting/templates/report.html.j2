<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>WCAG 2.1 AA Compliance Report — {{ filename | e }}</title>
<style>
/* ── Base ── */
:root {
  --pass: #1e8e3e; --pass-bg: #e6f4ea;
  --fail: #c5221f; --fail-bg: #fce8e6;
  --warn: #b06000; --warn-bg: #fef7e0;
  --review: #3f51b5; --review-bg: #e8eaf6;
  --na: #666; --na-bg: #f5f5f5;
  --text: #222; --bg: #fff; --border: #ccc;
  --header-bg: #f0f0f0;
}
@media (prefers-color-scheme: dark) {
  :root {
    --text: #e0e0e0; --bg: #1a1a1a; --border: #444;
    --header-bg: #2a2a2a;
    --pass-bg: #1b3a26; --fail-bg: #3a1b1b;
    --warn-bg: #3a2e1b; --review-bg: #1b1e3a; --na-bg: #2a2a2a;
  }
}
*, *::before, *::after { box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
       max-width: 1000px; margin: 0 auto; padding: 1em;
       color: var(--text); background: var(--bg); line-height: 1.5; }
a { color: var(--review); }
a.skip-link { position: absolute; left: -9999px; top: 0; padding: 0.5em 1em;
              background: var(--bg); z-index: 100; }
a.skip-link:focus { left: 0; }

/* ── Header ── */
header { border-bottom: 2px solid var(--text); padding-bottom: 0.5em; margin-bottom: 1em; }
header h1 { margin: 0 0 0.25em; font-size: 1.5em; }
.meta { display: grid; grid-template-columns: auto 1fr; gap: 0.25em 1em; font-size: 0.95em; }
.meta dt { font-weight: 600; }
.meta dd { margin: 0; }

/* ── Badge ── */
.badge { display: inline-block; padding: 0.3em 0.8em; border-radius: 4px;
         font-weight: 700; font-size: 1.1em; }
.badge.pass { background: var(--pass-bg); color: var(--pass); }
.badge.partial { background: var(--warn-bg); color: var(--warn); }
.badge.fail { background: var(--fail-bg); color: var(--fail); }

/* ── Progress bar ── */
.progress-bar { background: var(--na-bg); border-radius: 4px; height: 1.2em;
                overflow: hidden; margin: 0.5em 0; }
.progress-fill { height: 100%; background: var(--pass); transition: width 0.3s; }

/* ── Scorecard ── */
.scorecard { display: flex; flex-wrap: wrap; gap: 0.5em; margin: 1em 0; }
.score-item { padding: 0.4em 0.8em; border-radius: 4px; font-size: 0.9em; }
.score-pass { background: var(--pass-bg); color: var(--pass); }
.score-fail { background: var(--fail-bg); color: var(--fail); }
.score-review { background: var(--review-bg); color: var(--review); }
.score-na { background: var(--na-bg); color: var(--na); }

/* ── Tables ── */
table { border-collapse: collapse; width: 100%; margin: 1em 0; }
th, td { border: 1px solid var(--border); padding: 0.4em 0.6em;
         text-align: left; vertical-align: top; }
th { background: var(--header-bg); font-weight: 600; }
tr.row-pass td { background: var(--pass-bg); }
tr.row-fail td { background: var(--fail-bg); }
tr.row-warn td { background: var(--warn-bg); }
tr.row-review td { background: var(--review-bg); }
tr.row-na td { background: var(--na-bg); color: var(--na); }

/* ── Details ── */
details { margin: 0.5em 0; }
summary { cursor: pointer; font-weight: 600; padding: 0.3em 0; }
summary:focus { outline: 2px solid var(--review); outline-offset: 2px; }

/* ── Footer ── */
footer { border-top: 1px solid var(--border); margin-top: 2em; padding-top: 1em;
         color: var(--na); font-size: 0.85em; }

/* ── Print ── */
@media print {
  body { max-width: 100%; font-size: 10pt; }
  a.skip-link { display: none; }
  details[open] > summary { page-break-after: avoid; }
  tr { page-break-inside: avoid; }
  .badge, .score-item { border: 1px solid #000; }
}

/* ── Responsive ── */
@media (max-width: 600px) {
  .meta { grid-template-columns: 1fr; }
  table { font-size: 0.85em; }
  th, td { padding: 0.3em; }
  .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
}
</style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>

<header>
  <h1>WCAG 2.1 AA Compliance Report</h1>
  <p>WCAG 2.1 AA PDF Conversion &amp; Verification Tool v3</p>
</header>

<main id="main-content">
  <section aria-label="Document information">
    <dl class="meta">
      <dt>Document</dt><dd>{{ filename | e }}</dd>
      <dt>Title</dt><dd>{% if title %}{{ title | e }}{% else %}<em>(no title)</em>{% endif %}</dd>
      <dt>Processed</dt><dd>{{ timestamp | e }}</dd>
    </dl>
    <p><strong>Overall result:</strong>
      <span class="badge {{ overall | lower }}">{{ overall | e }}
        {%- if overall == "PASS" %} &#x2713;{% elif overall == "PARTIAL" %} &#x26A0;{% else %} &#x2717;{% endif -%}
      </span>
    </p>
  </section>

  <section aria-label="Summary scorecard">
    <h2>Summary</h2>
    {% set pass_count = checkpoints | selectattr("status", "equalto", "PASS") | list | length %}
    {% set fail_count = checkpoints | selectattr("status", "equalto", "FAIL") | list | length %}
    {% set review_count = checkpoints | selectattr("status", "equalto", "MANUAL_REVIEW") | list | length %}
    {% set na_count = checkpoints | selectattr("status", "equalto", "NOT_APPLICABLE") | list | length %}
    {% set warn_count = checkpoints | selectattr("status", "equalto", "INDETERMINATE") | list | length %}
    {% set total = checkpoints | length %}
    {% set pct = (pass_count * 100 // total) if total > 0 else 0 %}
    <div class="progress-bar" role="progressbar" aria-valuenow="{{ pct }}" aria-valuemin="0" aria-valuemax="100" aria-label="Compliance: {{ pct }}%">
      <div class="progress-fill" style="width:{{ pct }}%"></div>
    </div>
    <div class="scorecard">
      <span class="score-item score-pass">&#x2713; Passed: {{ pass_count }}</span>
      <span class="score-item score-fail">&#x2717; Failed: {{ fail_count }}</span>
      <span class="score-item score-review">&#x26A0; Manual Review: {{ review_count }}</span>
      <span class="score-item score-na">N/A: {{ na_count }}</span>
      {% if warn_count %}<span class="score-item score-na">Indeterminate: {{ warn_count }}</span>{% endif %}
    </div>
  </section>

  <section aria-label="Checkpoint details">
    <h2>Checkpoint Results</h2>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th scope="col">ID</th>
          <th scope="col">Check</th>
          <th scope="col">Status</th>
          <th scope="col">Detail</th>
        </tr>
      </thead>
      <tbody>
      {% for c in checkpoints %}
        {% set cls = {"PASS":"row-pass","FAIL":"row-fail","WARN":"row-warn","INDETERMINATE":"row-warn","NOT_APPLICABLE":"row-na","MANUAL_REVIEW":"row-review"}.get(c.status, "") %}
        {% set icon = {"PASS":"&#x2713;","FAIL":"&#x2717;","MANUAL_REVIEW":"&#x26A0;","NOT_APPLICABLE":"&mdash;"}.get(c.status, "?") %}
        <tr class="{{ cls }}">
          <td>{{ c.id | e }}</td>
          <td>{{ c.description | e }}</td>
          <td>{{ icon }} {{ c.status | e }}</td>
          <td>{{ c.detail | e }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    </div>
  </section>

  {% if manual_items %}
  <section aria-label="Manual review items">
    <details open>
      <summary>Manual Review Items</summary>
      <ul>
      {% for item in manual_items %}
        <li>{{ item | e }}</li>
      {% endfor %}
      </ul>
    </details>
  </section>
  {% endif %}

  {% if failed_steps %}
  <section aria-label="Pipeline issues">
    <details>
      <summary>Pipeline Steps with Issues</summary>
      <ul>
      {% for step in failed_steps %}
        <li>{{ step | e }}</li>
      {% endfor %}
      </ul>
    </details>
  </section>
  {% endif %}

  {% if auditor_error %}
  <section aria-label="Auditor error">
    <h2>Auditor Error</h2>
    <pre>{{ auditor_error | e }}</pre>
  </section>
  {% endif %}

  {% if ai_used %}
  <section aria-label="External data transfer notice">
    <h2>External Data Transfer Notice</h2>
    <p style="background:var(--warn-bg);border:1px solid var(--border);padding:0.5em 0.8em;border-radius:4px;">
      This document contains figure elements whose alt text was generated
      by Anthropic's Claude Vision API. Rendered images of those figures
      were transmitted to Anthropic for description. All other pipeline
      steps ran locally.
    </p>
  </section>
  {% endif %}

  <script type="application/json" id="wcag-audit-data">
{{ json_data | safe }}
  </script>
</main>

<noscript>
<section aria-label="Compliance results (no JavaScript)">
  <h2>Checkpoint Results</h2>
  <table>
    <thead><tr><th scope="col">ID</th><th scope="col">Check</th><th scope="col">Status</th><th scope="col">Detail</th></tr></thead>
    <tbody>
    {% for c in checkpoints %}
      <tr><td>{{ c.id | e }}</td><td>{{ c.description | e }}</td><td>{{ c.status | e }}</td><td>{{ c.detail | e }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>
</noscript>

<footer>
  <p>{{ privacy_text | e }}</p>
  <p>Generated by WCAG 2.1 AA PDF Conversion &amp; Verification Tool v3</p>
</footer>
</body>
</html>
